NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Demo mode — set to 1 to browse the app WITHOUT a live Supabase project.
# Bypasses auth (login button just enters), serves the WBS.xlsx sample data,
# and makes all writes no-ops. DEV/DEMO ONLY — never enable in production.
# Leave unset (or =0) for normal Supabase-backed operation.
NEXT_PUBLIC_DEMO_MODE=0

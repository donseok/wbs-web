NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 선택: DK Bot pgvector 마이그레이션 적용 스크립트(scripts/apply-dkbot-migration.*)용 DB 직결 URL.
# Dashboard > Project Settings > Database > Connection string > URI. 앱 런타임엔 불필요.
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# ── DK Bot (AI 챗봇) ──────────────────────────────────────────────
# 메뉴 인식형 v2는 안전한 점진 배포를 위해 명시적으로 켜야 합니다.
# 미설정/false이면 UI가 기존 /api/chat/stream으로 자동 복귀합니다.
# CHAT_V2_ENABLED=true
# 선택(실험적): v2 Evidence Pack을 LLM으로 문장화합니다.
# 미설정/false가 운영 기본값이며, 검증 가능한 결정형 근거 답변을 사용합니다.
# CHAT_V2_LLM_SYNTHESIS_ENABLED=true
# 선택(실험적): 모호하거나 교차 메뉴 질문에 제한된 2단계 도구 플래너(LLM)를 시도합니다.
# 미설정/false면 결정형 라우터와 기존 폴백만 사용합니다. LLM 키 필요.
# CHAT_V2_PLANNER_ENABLED=true
# ── DK Bot 증분 색인 워커(Phase 2 — 0031/0033 적용 후에만 의미 있음) ──
# 보호 라우트 /api/chat/index/worker 활성화 스위치. 미설정이면 라우트가 404입니다.
# CHAT_V2_INDEX_WORKER_ENABLED=true
# 워커 라우트 호출 시크릿(x-cron-secret 헤더). 미설정이면 라우트가 항상 404입니다.
# CHAT_V2_INDEX_CRON_SECRET=long-random-string
# 업무 쓰기 경로의 색인 작업 enqueue 스위치(현재 호출부 미배선 — 헬퍼만 존재).
# CHAT_V2_INDEX_ENQUEUE_ENABLED=true
# Google Gemini 무료 티어 키 하나로 LLM 답변 + pgvector 임베딩을 모두 처리합니다.
# 발급: https://aistudio.google.com/app/apikey  (서버 전용 — NEXT_PUBLIC_ 아님)
# 키가 없어도 봇은 동작합니다(구조화 질의 기반 결정형 답변으로 자동 폴백).
GEMINI_API_KEY=your-google-ai-studio-key
# 선택: 모델 오버라이드 (기본값 표기)
# GEMINI_MODEL=gemini-3.5-flash   # 무료 티어 지원 안정판. 2.5-flash 는 2026-10-16 셧다운, Pro 계열은 무료 쿼터 0(429) → 쓰지 말 것
# GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-3-flash-preview   # 주 모델 429/5xx 시 순서대로 시도(모델별 쿼터 버킷 분리). ""(빈 값)이면 폴백 없음
# GEMINI_EMBED_MODEL=gemini-embedding-001   # 768차원으로 축소(outputDimensionality) → vector(768)

# 선택: OpenAI 호환 엔드포인트(Groq/OpenRouter/사내 LLM)로 전환하려면:
# AI_PROVIDER=openai
# LLM_API_KEY=...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# EMBED_MODEL=text-embedding-3-small   # ⚠ 차원(1536)에 맞춰 마이그레이션 vector(...) 변경 필요

# ── 회의록 업로드 API (또박또박 연동 — docs/design/dflow-minutes-upload-api-spec.md) ──
# 두 값이 모두 설정돼야 /api/v1/minutes* 가 열립니다. 미설정이면 전 라우트 404(존재 은닉).
# MINUTES_API_ENABLED=true
# 시크릿 생성: openssl rand -base64 48 — 또박또박 서버(Rails)에만 보안 채널로 전달, 평문 커밋 금지.
# MINUTES_API_SECRET=long-random-string

# ── 회의 안내 메일 (Gmail SMTP) ──
# SMTP_PASS 는 Google '앱 비밀번호'다. 계정 비밀번호가 아니며 2단계 인증이 켜져 있어야 발급된다.
# 미설정이면 발송 액션이 throw 하지 않고 { ok:false } 를 반환한다(로컬·Preview 정상 동작).
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=D-CUBE 회의알림
# 메일 본문 링크의 절대 주소. 없으면 VERCEL_PROJECT_PRODUCTION_URL 로 폴백, 그것도 없으면 링크 생략.
NEXT_PUBLIC_APP_URL=

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 선택: DK Bot pgvector 마이그레이션 적용 스크립트(scripts/apply-dkbot-migration.*)용 DB 직결 URL.
# Dashboard > Project Settings > Database > Connection string > URI. 앱 런타임엔 불필요.
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# ── DK Bot (AI 챗봇) ──────────────────────────────────────────────
# Google Gemini 무료 티어 키 하나로 LLM 답변 + pgvector 임베딩을 모두 처리합니다.
# 발급: https://aistudio.google.com/app/apikey  (서버 전용 — NEXT_PUBLIC_ 아님)
# 키가 없어도 봇은 동작합니다(구조화 질의 기반 결정형 답변으로 자동 폴백).
GEMINI_API_KEY=your-google-ai-studio-key
# 선택: 모델 오버라이드 (기본값 표기)
# GEMINI_MODEL=gemini-3.5-flash   # 무료 티어 지원 안정판. 2.5-flash 는 2026-10-16 셧다운, Pro 계열은 무료 쿼터 0(429) → 쓰지 말 것
# GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-2.5-flash-lite   # 주 모델 429/5xx 시 순서대로 시도(모델별 쿼터 버킷 분리). ""(빈 값)이면 폴백 없음
# GEMINI_EMBED_MODEL=gemini-embedding-001   # 768차원으로 축소(outputDimensionality) → vector(768)

# 선택: OpenAI 호환 엔드포인트(Groq/OpenRouter/사내 LLM)로 전환하려면:
# AI_PROVIDER=openai
# LLM_API_KEY=...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# EMBED_MODEL=text-embedding-3-small   # ⚠ 차원(1536)에 맞춰 마이그레이션 vector(...) 변경 필요
